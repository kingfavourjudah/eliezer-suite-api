# ── Server ───────────────────────────────────────────────────────────────────
PORT=3100

# ── x402 Payment ─────────────────────────────────────────────────────────────
# Wallet that receives x402 USDC payments from API consumers
SERVER_WALLET_ADDRESS=0xYourServerWalletAddress
SERVER_PRIVATE_KEY=0xYourServerPrivateKey   # used to verify ownership only, never spends

# Chain: 421614 = Arbitrum Sepolia (testnet), 42161 = Arbitrum One (mainnet)
CHAIN_ID=421614

# USDC contract on the configured chain
# Arbitrum Sepolia: 0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
# Arbitrum One:     0xaf88d065e77c8cC2239327C5EDb3A432268e5831
USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# Price (in USDC) charged per API call
SHIPPING_RATE_PRICE_USDC=0.10
COMPLIANCE_SCREEN_PRICE_USDC=0.05

# ── Carrier APIs (optional — add as you integrate) ───────────────────────────
# DHL Express API
DHL_API_KEY=
DHL_API_SECRET=

# Freightos / WebCargo
FREIGHTOS_API_KEY=

# Flexport
FLEXPORT_API_KEY=

# ── Compliance Data Sources ───────────────────────────────────────────────────
# OpenSanctions API (free tier: https://www.opensanctions.org/api/)
OPENSANCTIONS_API_KEY=

# OFAC SDN list is fetched directly from the US Treasury (no key required)
# Cached locally and refreshed every 24 hours
OFAC_REFRESH_INTERVAL_MS=86400000

# ── Exchange Rates ─────────────────────────────────────────────────────────────
# Used to convert shipping quotes to CNY / NGN for display
EXCHANGE_RATE_API_KEY=     # https://www.exchangerate-api.com (free tier available)
